using System;
using System.Collections.Generic;
using System.Linq;
using System.Text;
using System.Threading.Tasks;

namespace Bai16
{
    internal class Program
    {
        static string XoaTrungLap(string s)
        {
            string ketQua = "";

            foreach (char c in s)
            {
                // Nếu chuỗi ketQua chưa chứa ký tự c thì thêm vào
                if (!ketQua.Contains(c.ToString()))
                {
                    ketQua += c;
                }
            }
            return ketQua;
        }
        static void Main(string[] args)
        {
            Console.WriteLine(XoaTrungLap("programming")); // Output: "progamin"
        }
    }
}
