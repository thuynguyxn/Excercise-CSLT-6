using System;
using System.Collections.Generic;
using System.Linq;
using System.Text;
using System.Threading.Tasks;

namespace Bai7
{
    internal class Program
    {
        static void InFibonacci(int n)
        {
            if (n <= 0) return;

            int f0 = 0, f1 = 1;

            for (int i = 0; i < n; i++)
            {
                Console.Write(f0 + " ");

                // Tính số tiếp theo và dịch chuyển biến
                int next = f0 + f1;
                f0 = f1;
                f1 = next;
            }
            Console.WriteLine(); // Xuống dòng khi in xong
        }
        static void Main(string[] args)
        {
            Console.Write("Nhap n so Fibonacci can in: ");
            int n = Convert.ToInt32(Console.ReadLine());
            InFibonacci(n);
        }
    }
}
