using System;
using System.Collections.Generic;
using System.Linq;
using System.Text;
using System.Threading.Tasks;

namespace Bai8
{
    internal class Program
    {
        static int DemNguyenAm(string s)
        {
            int count = 0;
            // Chuyển về chữ thường để gom nhóm điều kiện kiểm tra
            string lowerStr = s.ToLower();

            foreach (char c in lowerStr)
            {
                // Kiểm tra ký tự có nằm trong danh sách nguyên âm không
                if (c == 'a' || c == 'e' || c == 'i' || c == 'o' || c == 'u')
                {
                    count++;
                }
            }
            return count;
        }
        static void Main(string[] args)
        {
            Console.Write("Nhap vao mot chuoi: ");
            string input = Console.ReadLine();
            Console.WriteLine($"So luong nguyen am: {DemNguyenAm(input)}");
        }
    }
}
